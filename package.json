{
  "name": "streamer-copilot",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop app for streamers with unified chat and automations",
  "author": {
    "name": "Paulo Manrique",
    "email": "paulo@manriq.dev"
  },
  "type": "module",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json --watch",
    "dev:app": "wait-on tcp:127.0.0.1:5174 dist/main/index.js dist/preload/index.cjs && electron dist/main/index.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "clean:release": "node -e \"require('node:fs').rmSync('release', { recursive: true, force: true })\"",
    "start": "cross-env ELECTRON_RUN_AS_NODE= electron dist/main/index.js",
    "package": "npm run build && npm run rebuild:native && electron-builder --config electron-builder.yml",
    "package:mac": "npm run build && npm run rebuild:native && electron-builder --config electron-builder.yml --mac",
    "package:win": "npm run build && npm run rebuild:native && electron-builder --config electron-builder.yml --win",
    "package:linux": "npm run build && npm run rebuild:native && electron-builder --config electron-builder.yml --linux",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "validate:ipc": "tsx scripts/validate-ipc-sync.ts",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@legendapp/list": "^3.0.0-beta.44",
    "@nekiro/kick-api": "^2.1.2",
    "@sefinek/google-tts-api": "^2.1.13",
    "better-sqlite3": "^12.4.1",
    "electron-updater": "^6.8.3",
    "googleapis": "^171.4.0",
    "music-metadata": "^11.12.3",
    "obs-websocket-js": "^5.0.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tiktok-live-connector": "^2.1.1-beta1",
    "tmi.js": "^1.8.5",
    "ws": "^8.20.0",
    "youtubei.js": "^17.0.1",
    "zod": "^4.1.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.2",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "postcss": "^8.5.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "google-auth-library": "10.5.0"
  }
}
